# Notion
NOTION_API_KEY=your_notion_api_key
NOTION_DATABASE_ID=your_notion_database_id

# Upload target
# Compatible with a self-hosted upload service that returns a public download URL.
# Example self-use endpoint:
#   https://stor.pull.eu.org/upload
#
# Notes:
# - The current self-use backend benefits from the CloudFlare-ImgBed project:
#   https://github.com/MarSeventh/CloudFlare-ImgBed
# - If your backend is backed by Telegram-group/channel storage, treat it as cost-effective
#   but not risk-free: keep local backups and assume bans / rate limits / broken links are possible.
UPLOAD_URL=https://stor.example.com/upload
UPLOAD_TOKEN=your_upload_token

# Optional: cookies for better video-site stability
# Prefer VIDEO_COOKIES_FILE; BILI_COOKIES_FILE remains backward-compatible for older setups.
VIDEO_COOKIES_FILE=/absolute/path/to/video_site_cookies.txt

# Local paths
PIPELINE_DATA_DIR=./data
BILI_DOWNLOAD_DIR=./data/downloads/bilibili
BILI_TEMP_DIR=./data/bili_temp

# Transcription
WHISPER_MODEL=small
WHISPER_LANGUAGE=zh
WHISPER_COMPUTE_TYPE=auto

# Long-video ASR strategy
# Auto-enable segmented transcription when audio duration exceeds this many minutes.
ASR_AUTO_SEGMENT_MINUTES=20
# Segment length in seconds for long-video transcription.
ASR_SEGMENT_SECONDS=600
